---
import Layout from '@layouts/Default.astro';
import { getCollection, getEntry } from '@lib/content';
import { HOMEPAGE_SLUG } from './index.astro';
import { CONCERTS_SLUG } from '@content/Concerts';

import ContentPage from '@layouts/Pages/ContentPage/ContentPage.astro';

export async function getStaticPaths() {
  const excludedSlugs = [HOMEPAGE_SLUG, CONCERTS_SLUG];
  const pages = await getCollection(
    'Pages',
    (page) => !excludedSlugs.includes(page.data.slug),
  );
  return pages.map(({ data: page }) => ({
    params: { path: page.slug },
  }));
}

const { path } = Astro.params;
const entry = await getEntry('Pages', path);
if (!entry) {
  return Astro.rewrite('/404/');
}

const indexPage = !entry.data.indexPage
  ? {
    tag: 'meta',
    attributes: {
      name: 'robots',
      content: 'noindex,nofollow',
    },
  }
  : null;
---

<Layout
  seoMetaTags={[
    ...(entry.data._seoMetaTags || []),
    ...(indexPage ? [indexPage] : []),
  ]}
>
  <ContentPage data={entry.data} />
</Layout>
