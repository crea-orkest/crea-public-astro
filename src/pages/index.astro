---
import Layout from '@layouts/Default.astro';
import HomePage from '@layouts/Pages/HomePage/HomePage.astro';
import { getCollection, getEntry } from '@lib/content';
export const HOMEPAGE_SLUG = 'homepage';

const { data } = (await getEntry('Pages', HOMEPAGE_SLUG))!;
const concerts = await getCollection('Concerts');
---

<Layout seoMetaTags={data._seoMetaTags}>
  <HomePage data={data} concert={concerts[0].data} />
</Layout>
