---
import { CONCERTS_SLUG } from '@content/Concerts';
import Layout from '@layouts/Default.astro';
import ConcertOverviewPage from '@layouts/Pages/ConcertOverviewPage/ConcertOverviewPage.astro';
import { getCollection, getEntry } from '@lib/content';

const entry = (await getEntry('Pages', CONCERTS_SLUG))!;

const concerts = await getCollection('Concerts');
---

<Layout>
  <ConcertOverviewPage
    data={entry.data}
    concerts={concerts.map((concert) => concert.data)}
  />
</Layout>
